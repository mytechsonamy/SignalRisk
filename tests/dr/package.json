{
  "name": "@signalrisk/dr-tests",
  "version": "0.1.0",
  "description": "SignalRisk disaster recovery validation tests",
  "private": true,
  "scripts": {
    "test": "jest --no-coverage",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.spec.ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "tsconfig": {
          "strict": false,
          "esModuleInterop": true
        }
      }]
    }
  }
}
