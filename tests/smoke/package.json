{
  "name": "@signalrisk/smoke-tests",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "TESTCONTAINERS_RYUK_DISABLED=true jest --passWithNoTests --testTimeout=60000 --forceExit",
    "test:verbose": "TESTCONTAINERS_RYUK_DISABLED=true jest --passWithNoTests --testTimeout=60000 --forceExit --verbose"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.2",
    "ioredis": "^5.10.0",
    "jest": "^29.5.0",
    "pg": "^8.11.3",
    "testcontainers": "^10.28.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node",
    "testTimeout": 60000
  }
}
