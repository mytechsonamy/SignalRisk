{
  "name": "@signalrisk/e2e-tests",
  "version": "0.1.0",
  "description": "SignalRisk E2E test suite - Jest + Supertest",
  "private": true,
  "scripts": {
    "test": "jest --config jest.config.ts --runInBand",
    "test:parallel": "jest --config jest.config.ts --maxWorkers=4",
    "test:isolation": "jest --config jest.config.ts --testPathPattern=isolation",
    "test:e2e": "jest --config jest.config.ts --testPathPattern=e2e",
    "test:coverage": "jest --config jest.config.ts --coverage --runInBand"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "supertest": "^6.3.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
