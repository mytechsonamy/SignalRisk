{
  "name": "@signalrisk/integration-tests",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "jest --passWithNoTests --testTimeout=30000 --forceExit"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "testEnvironment": "node",
    "testTimeout": 30000
  }
}
