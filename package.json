{
  "name": "signalrisk-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tests/smoke",
    "tests/e2e",
    "tests/dr",
    "tests/compliance",
    "tests/docs"
  ],
  "scripts": {
    "test:all": "npm run test --workspaces --if-present 2>&1 || true",
    "build:all": "npm run build --workspaces --if-present 2>&1 || true",
    "lint:all": "npm run lint --workspaces --if-present 2>&1 || true"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "tsc-alias": "^1.8.10"
  },
  "dependencies": {
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
