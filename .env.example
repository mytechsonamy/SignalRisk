# =============================================================================
# SignalRisk — Environment Variables
# Copy this file to .env and adjust values for your local setup
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=signalrisk
POSTGRES_PASSWORD=signalrisk_dev
POSTGRES_DB=signalrisk
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# PgBouncer
# -----------------------------------------------------------------------------
PGBOUNCER_PORT=6432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_PORT=9092
KAFKA_UI_PORT=8080

# -----------------------------------------------------------------------------
# Auth / JWT
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=3600

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# External API Keys (optional, for integration services)
# -----------------------------------------------------------------------------
# TELCO_API_KEY=
# TELCO_API_URL=
# IPQS_API_KEY=
# MAXMIND_LICENSE_KEY=
