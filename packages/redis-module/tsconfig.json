{
  "compilerOptions": {
    "target": "ES2019", "module": "commonjs", "declaration": true,
    "outDir": "dist", "strict": true, "esModuleInterop": true,
    "experimentalDecorators": true, "emitDecoratorMetadata": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"], "exclude": ["src/**/*.spec.ts"]
}
