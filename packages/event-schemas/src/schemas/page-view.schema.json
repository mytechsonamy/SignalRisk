{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://signalrisk.com/schemas/page-view-payload.json",
  "title": "PAGE_VIEW Payload",
  "description": "Payload schema for PAGE_VIEW events",
  "type": "object",
  "required": ["url"],
  "properties": {
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Page URL visited"
    },
    "referrer": {
      "type": "string",
      "description": "Referring URL"
    },
    "viewport": {
      "type": "object",
      "properties": {
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 }
      },
      "required": ["width", "height"],
      "additionalProperties": false,
      "description": "Browser viewport dimensions"
    },
    "scrollDepth": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Maximum scroll depth as percentage (0-100)"
    },
    "title": {
      "type": "string",
      "description": "Page title"
    },
    "loadTimeMs": {
      "type": "integer",
      "minimum": 0,
      "description": "Page load time in milliseconds"
    }
  },
  "additionalProperties": false
}
