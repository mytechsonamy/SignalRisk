{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://signalrisk.com/schemas/signup-payload.json",
  "title": "SIGNUP Payload",
  "description": "Payload schema for SIGNUP events",
  "type": "object",
  "required": ["method"],
  "properties": {
    "method": {
      "type": "string",
      "enum": ["email", "phone", "social", "sso"],
      "description": "Signup method used"
    },
    "emailDomain": {
      "type": "string",
      "description": "Domain portion of the registration email"
    },
    "fillTimeMs": {
      "type": "integer",
      "minimum": 0,
      "description": "Time taken to complete signup form in milliseconds"
    },
    "pageLoadToSubmitMs": {
      "type": "integer",
      "minimum": 0,
      "description": "Time from page load to form submission in milliseconds"
    },
    "fieldCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of form fields filled"
    },
    "referralSource": {
      "type": "string",
      "description": "How the user arrived at the signup page"
    }
  },
  "additionalProperties": false
}
